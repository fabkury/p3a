menu "Makapix Configuration"

    config MAKAPIX_CLUB_HOST
        string "Makapix Club Host"
        default "makapix.club"
        help
            Hostname of the Makapix Club server for provisioning and API calls.

    config MAKAPIX_VAULT_HOST
        string "Makapix Club Vault Host"
        default "vault.makapix.club"
        help
            Hostname serving Makapix Club artwork files, as
            https://{vault_host}/{shard}/{storage_key}.{ext}. Faster than the
            deprecated https://{club_host}/api/vault/... form it replaces.

    config MAKAPIX_CLUB_MQTT_PORT
        int "Makapix Club MQTT Port"
        default 8883
        range 1 65535
        help
            Port number for the Makapix Club MQTT broker.
            Default is 8883 for TLS/mTLS connections.

    config MAKAPIX_CERT_RENEW_WINDOW_DAYS
        int "Certificate renewal window (days before expiry)"
        default 45
        range 1 3650
        help
            The device starts trying to renew its MQTT client certificate
            once it is within this many days of the certificate's notAfter.
            Must not exceed the server's CERT_RENEWAL_THRESHOLD_DAYS (90 in
            production) or the server rejects the attempts with HTTP 400
            until the server-side window opens. Values above 90 are for
            end-to-end testing against a dev server whose threshold has been
            raised to match (e.g. 3650 makes a fresh 3-year cert immediately
            renewable on both sides).

    config MAKAPIX_CERT_RENEW_CHECK_HOURS
        int "Certificate renewal check interval (hours)"
        default 24
        range 1 168
        help
            How often the renewal task re-evaluates the stored client
            certificate's remaining lifetime.

endmenu

