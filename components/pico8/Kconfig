menu "P3A Features"

menu "PICO-8 Streaming"

    config P3A_PICO8_ENABLE
        bool "Enable PICO-8 streaming support"
        default y
        help
            Enable PICO-8 pixel art streaming over USB/WebSocket.
            When disabled, PICO-8 streaming functions are stubbed out.

    if P3A_PICO8_ENABLE

        config P3A_PICO8_MODE_TIMEOUT_MS
            int "PICO-8 mode timeout (ms)"
            default 30000
            range 5000 120000
            help
                Time in milliseconds after which PICO-8 mode will automatically
                exit if no frames are received. This prevents the display from
                being stuck in PICO-8 mode if the connection is lost.

        config P3A_PICO8_USB_STREAM_ENABLE
            bool "Enable USB PICO-8 streaming interface"
            default y
            depends on P3A_USB_MSC_ENABLE
            help
                Add vendor-specific USB interface for PICO-8 frame streaming.
                Requires USB MSC to be enabled.

        config P3A_PICO8_AUDIO_ENABLE
            bool "Enable PICO-8 audio streaming"
            default y
            help
                Enable streaming PICO-8 game audio to the on-board speaker.
                Requires the ES8311 audio codec and NS4150B amplifier.

        if P3A_PICO8_AUDIO_ENABLE

            config P3A_PICO8_AUDIO_VOLUME
                int "Default PICO-8 audio volume (0-100)"
                default 60
                range 0 100
                help
                    Default hardware volume for PICO-8 audio playback.
                    Acts as a master ceiling; the browser applies per-session
                    volume scaling on top.

            config P3A_PICO8_AUDIO_BUFFER_SIZE
                int "Audio ring buffer size (bytes)"
                default 4096
                range 2048 16384
                help
                    Size of the ring buffer for audio sample delivery.
                    Larger values absorb more jitter but add latency.

        endif # P3A_PICO8_AUDIO_ENABLE

    endif # P3A_PICO8_ENABLE

endmenu # PICO-8 Streaming

endmenu # P3A Features

