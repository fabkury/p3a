menu "Play Scheduler"

    config PLAY_SCHEDULER_HISTORY_SIZE
        int "History buffer size"
        default 32
        range 8 128
        help
            Number of previously played artworks to keep in history.
            Allows navigation back through recently played items.

    config PLAY_SCHEDULER_MAX_CHANNELS
        int "Maximum channels"
        default 64
        range 1 64
        help
            Maximum number of channels that can be active simultaneously.

endmenu
